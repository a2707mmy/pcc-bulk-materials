          },
          {
            "name": "預拌均價",
            "expression": "CALCULATE([平均單價], fact_price_history[material]=\"預拌混凝土\")",
            "formatString": "#,0",
            "lineageTag": "2ec4930b-c112-4a8c-b6f7-3762574b2f7d"
          },
          {
            "name": "瀝青均價",
            "expression": "CALCULATE([平均單價], fact_price_history[material]=\"瀝青混凝土\")",
            "formatString": "#,0",
            "lineageTag": "14850948-d003-4aaa-ad3f-6084bfcdf54a"
          },
          {
            "name": "鋼筋現價",
            "expression": "VAR d=[_最新期] RETURN CALCULATE([平均單價], fact_price_history[material]=\"鋼筋\", fact_price_history[period_date]=d)",
            "formatString": "#,0",
            "lineageTag": "f3002299-8a46-493a-bdad-061f8d91a7c3"
          },
          {
            "name": "瀝青現價",
            "expression": "VAR d=[_最新期] RETURN CALCULATE([平均單價], fact_price_history[material]=\"瀝青混凝土\", fact_price_history[period_date]=d)",
            "formatString": "#,0",
            "lineageTag": "122fe734-8def-487c-a7cb-3e9258df9db1"
          },
          {
            "name": "預拌現價",
            "expression": "VAR d=[_最新期] RETURN CALCULATE([平均單價], fact_price_history[material]=\"預拌混凝土\", fact_price_history[period_date]=d)",
            "formatString": "#,0",
            "lineageTag": "fb899937-25dc-46b1-abbd-db4704f38dab"
          },
          {
            "name": "H型鋼現價",
            "expression": "VAR d=[_最新期] RETURN CALCULATE([平均單價], fact_price_history[material]=\"H型鋼\", fact_price_history[period_date]=d)",
            "formatString": "#,0",
            "lineageTag": "12e078e2-3dae-45f9-a3cf-1294ca02bf3c"
          },
          {
            "name": "鋼筋年漲跌",
            "expression": "VAR d=[_最新期] VAR c=CALCULATE([平均單價],fact_price_history[material]=\"鋼筋\",fact_price_history[period_date]=d) VAR p=CALCULATE([平均單價],fact_price_history[material]=\"鋼筋\",fact_price_history[period_date]=EDATE(d,-12)) RETURN DIVIDE(c-p,p)",
            "formatString": "0.0%",
            "lineageTag": "77ba145e-ed08-454b-bf6b-ae7a2ddbba59"
          },
          {
            "name": "瀝青年漲跌",
            "expression": "VAR d=[_最新期] VAR c=CALCULATE([平均單價],fact_price_history[material]=\"瀝青混凝土\",fact_price_history[period_date]=d) VAR p=CALCULATE([平均單價],fact_price_history[material]=\"瀝青混凝土\",fact_price_history[period_date]=EDATE(d,-12)) RETURN DIVIDE(c-p,p)",
            "formatString": "0.0%",
            "lineageTag": "0437f259-50ed-4da8-8f8a-159715286797"
          },
          {
            "name": "預拌年漲跌",
            "expression": "VAR d=[_最新期] VAR c=CALCULATE([平均單價],fact_price_history[material]=\"預拌混凝土\",fact_price_history[period_date]=d) VAR p=CALCULATE([平均單價],fact_price_history[material]=\"預拌混凝土\",fact_price_history[period_date]=EDATE(d,-12)) RETURN DIVIDE(c-p,p)",
            "formatString": "0.0%",
            "lineageTag": "18be032d-3fc4-4a46-838a-a88cef3a1c5e"
          },
          {
            "name": "H型鋼年漲跌",
            "expression": "VAR d=[_最新期] VAR c=CALCULATE([平均單價],fact_price_history[material]=\"H型鋼\",fact_price_history[period_date]=d) VAR p=CALCULATE([平均單價],fact_price_history[material]=\"H型鋼\",fact_price_history[period_date]=EDATE(d,-12)) RETURN DIVIDE(c-p,p)",
            "formatString": "0.0%",
            "lineageTag": "2cc09709-0953-4a8e-aa02-02937375a0d3"
          },
          {
            "name": "年漲跌",
            "expression": "VAR d=[_最新期] VAR c=CALCULATE([平均單價],fact_price_history[period_date]=d) VAR p=CALCULATE([平均單價],fact_price_history[period_date]=EDATE(d,-12)) RETURN DIVIDE(c-p,p)",
            "formatString": "0.0%",
            "lineageTag": "33b098bd-cdd9-4ed4-8bce-cf63b2858bfd"
          },
          {
            "name": "_選月數",
            "expression": "SELECTEDVALUE(期間選項[月數], 9999)",
            "isHidden": true,
            "lineageTag": "af114894-8d59-4eb1-b4c2-191982ed6d0c"
          },
          {
            "name": "在範圍內",
            "expression": "VAR sel=[_選月數] VAR d=[_最新期] RETURN IF(sel>=9999, 1, IF(MAX(fact_price_history[period_date]) > EDATE(d, -sel), 1, 0))",
            "isHidden": true,
            "lineageTag": "95937c2d-f312-44d6-ba54-bb9ccc14ffcf"
          },
          {
            "name": "鋼筋均價R",
            "expression": "IF([在範圍內]=1, [鋼筋均價])",
            "formatString": "#,0",
            "lineageTag": "21d2d481-0694-41ae-8e05-300c964b1ecb"
          },
          {
            "name": "H型鋼均價R",
            "expression": "IF([在範圍內]=1, [H型鋼均價])",
            "formatString": "#,0",
            "lineageTag": "7f83715d-28eb-473e-b349-d3b9a5c3b8df"
          },
          {
            "name": "鋼板均價R",
            "expression": "IF([在範圍內]=1, [鋼板均價])",
            "formatString": "#,0",
            "lineageTag": "7dc04fb5-ed45-42dd-b812-6189736b2bae"
          },
          {
            "name": "預拌均價R",
            "expression": "IF([在範圍內]=1, [預拌均價])",
            "formatString": "#,0",
            "lineageTag": "2aa726b6-fc89-458b-8361-64ae55720122"
          },
          {
            "name": "瀝青均價R",
            "expression": "IF([在範圍內]=1, [瀝青均價])",
            "formatString": "#,0",
            "lineageTag": "aca89225-d87f-4eb8-a478-9be1169564fe"
          }
        ],
        "partitions": [
          {
            "name": "fact_price_history",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    HSrc = Csv.Document(Web.Contents(\"https://raw.githubusercontent.com/a2707mmy/pcc-bulk-materials/main/data/history/material_price_history.csv\"), [Delimiter = \",\", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),",
                "    HP = Table.PromoteHeaders(HSrc, [PromoteAllScalars = true]),",
                "    HT = Table.TransformColumnTypes(HP, {{\"period_date\", type date}, {\"price\", type number}, {\"price_min\", type number}, {\"price_max\", type number}}, \"en-US\"),",
                "    代表 = Table.SelectRows(HT, each ((([material]=\"鋼筋\" and ((Text.Contains([item_name],\"SD280\") and Text.Contains([item_name],\"D10\")) or (Text.Contains([item_name],\"SD420\") and Text.Contains([item_name],\"D36\")))) or ([material]=\"預拌混凝土\" and (Text.Contains([item_name],\"210kgf\") or Text.Contains([item_name],\"280kgf\"))) or ([material]=\"瀝青混凝土\" and ((Text.Contains([item_name],\"粗級配\") and Text.Contains([item_name],\"25mm\")) or (Text.Contains([item_name],\"密級配\") and Text.Contains([item_name],\"19mm\")))) or ([material]=\"H型鋼\" and Text.Contains([item_name],\"H400\")) or ([material]=\"鋼板\" and Text.Contains([item_name],\"A36\"))))),",
                "    HS = Table.SelectColumns(代表, {\"period\",\"period_roc\",\"period_date\",\"material\",\"item_name\",\"unit\",\"region\",\"region_group\",\"region_level\",\"price\",\"price_min\",\"price_max\",\"price_basis\"}),",
                "    加材料組 = Table.AddColumn(HS, \"材料組\", each if List.Contains({\"鋼筋\",\"H型鋼\",\"鋼板\"}, [material]) then \"鋼材\" else \"混凝土瀝青\", type text),",
                "    加規格 = Table.AddColumn(加材料組, \"規格\", each if Text.Contains([item_name],\"SD280\") then \"SD280\" else if Text.Contains([item_name],\"SD420\") then \"SD420\" else if Text.Contains([item_name],\"210kgf\") then \"210\" else if Text.Contains([item_name],\"280kgf\") then \"280\" else if (Text.Contains([item_name],\"粗級配\") and Text.Contains([item_name],\"25mm\")) then \"粗25\" else if (Text.Contains([item_name],\"密級配\") and Text.Contains([item_name],\"19mm\")) then \"密19\" else if Text.Contains([item_name],\"A36\") then \"A36\" else if Text.Contains([item_name],\"H型鋼\") then \"H400\" else [material], type text),",
                "    去重 = Table.Distinct(加規格, {\"period\",\"material\",\"規格\",\"region_group\"}),",
                "    加材料規格 = Table.AddColumn(去重, \"材料規格\", each [material] & \" \" & [規格], type text),",
                "    加年月碼 = Table.AddColumn(加材料規格, \"年月碼\", each Date.Year([period_date])*100 + Date.Month([period_date]), Int64.Type)",
                "in",
                "    加年月碼"
              ],
              "type": "m"
            }
          }
        ]
      },
