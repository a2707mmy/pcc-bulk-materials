        "partitions": [
          {
            "name": "期間選項",
            "mode": "import",
            "source": {
              "expression": "DATATABLE(\"選項\", STRING, \"月數\", INTEGER, \"排序\", INTEGER, {{\"近1月\",1,1},{\"近1年\",12,2},{\"近3年\",36,3},{\"全期\",9999,4}})",
              "type": "calculated"
            }
          }
        ]
      }
    ]
  }
