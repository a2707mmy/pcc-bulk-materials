        "lineageTag": "a80c3374-d4fa-44eb-b6d4-5411677bbb9b",
        "measures": [
          {
            "name": "平均單價",
            "expression": "AVERAGE(fact_price_history[price])",
            "formatString": "#,0",
            "lineageTag": "b7a16612-72f8-40db-a38d-f5ae622d8cd9"
          },
          {
            "name": "_最新期",
            "expression": "CALCULATE(MAX(fact_price_history[period_date]), ALL(fact_price_history))",
            "isHidden": true,
            "lineageTag": "59c016f4-54a0-4a89-90ca-398ebd39eca7"
          },
          {
            "name": "鋼筋均價",
            "expression": "CALCULATE([平均單價], fact_price_history[material]=\"鋼筋\")",
            "formatString": "#,0",
            "lineageTag": "5b87b308-cb47-4341-9dad-d793e2c3805b"
          },
          {
            "name": "H型鋼均價",
            "expression": "CALCULATE([平均單價], fact_price_history[material]=\"H型鋼\")",
            "formatString": "#,0",
