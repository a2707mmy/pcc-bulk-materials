	partition 重估時間 = calculated
		mode: import
		source = ADDCOLUMNS(DISTINCT(SELECTCOLUMNS(fact_price_history,"重估月",fact_price_history[period_date])),"重估月標籤","民國 " & (YEAR([重估月])-1911) & "/" & MONTH([重估月]),"排序鍵", YEAR([重估月])*100+MONTH([重估月]))

