	measure 資料截至文字 = VAR d=[_最新期] RETURN "資料截至 民國 " & (YEAR(d)-1911) & "/" & MONTH(d) & " · 來源：工程會價格趨勢"
		lineageTag: 24ea430b-f277-4c0f-bf38-2f789e9650d8

	measure 領漲文字 = VAR tbl={("鋼筋",[鋼筋年漲跌]),("H型鋼",[H型鋼年漲跌]),("鋼板",[鋼板年漲跌]),("預拌混凝土",[預拌年漲跌])} VAR nm=MAXX(TOPN(1,tbl,[Value2]),[Value1]) VAR v=MAXX(tbl,[Value2]) VAR n5=COUNTROWS(FILTER(tbl,[Value2]>0.05)) RETURN nm & " 領漲，近一年 +" & FORMAT(v,"0.0%") & "：四項橋梁大宗材料中有 " & n5 & " 項近一年漲幅超過 5%，編列中或待發包工程材料成本恐高於原估。"
		lineageTag: 13146395-c656-494a-9d8b-9346b040c7c7

	measure 領漲幅度文字 = VAR tbl={("鋼筋",[鋼筋年漲跌]),("H型鋼",[H型鋼年漲跌]),("鋼板",[鋼板年漲跌]),("預拌混凝土",[預拌年漲跌])} VAR v=MAXX(tbl,[Value2]) RETURN "+" & FORMAT(v,"0.0%")
		lineageTag: 7157059f-e5d0-4212-954f-64e5ef811d4b

	measure 領漲副標 = VAR tbl={("鋼筋",[鋼筋年漲跌]),("H型鋼",[H型鋼年漲跌]),("鋼板",[鋼板年漲跌]),("預拌混凝土",[預拌年漲跌])} VAR nm=MAXX(TOPN(1,tbl,[Value2]),[Value1]) RETURN nm & " · 近一年"
		lineageTag: 416993dc-2dc1-4d17-95c0-00a5b791b87a

