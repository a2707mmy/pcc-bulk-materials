	partition 原始時間 = calculated
		mode: import
		source = ADDCOLUMNS(DISTINCT(SELECTCOLUMNS(fact_price_history,"原始月",fact_price_history[period_date])),"原始月標籤","民國 " & (YEAR([原始月])-1911) & "/" & MONTH([原始月]),"排序鍵", YEAR([原始月])*100+MONTH([原始月]))

